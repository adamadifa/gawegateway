# ============================================================
# GaweGateway Node Service - Environment Variables
# ============================================================
# Copy file ini ke .env dan sesuaikan nilainya

# Port untuk Node.js service
PORT=3001

# URL Laravel backend (tanpa trailing slash)  
# Di VPS, ganti ke URL internal, contoh: http://127.0.0.1:8000
LARAVEL_URL=http://localhost:8000

# CORS origin - domain yang diizinkan akses Socket.IO
# Di production, ganti ke domain kamu, contoh: https://wa.domainmu.com
CORS_ORIGIN=*

# Maksimal percobaan reconnect saat koneksi putus
MAX_RETRIES=5

# Maksimal percobaan regenerate QR Code saat tidak ada yang scan
MAX_QR_RETRIES=3

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=warn
